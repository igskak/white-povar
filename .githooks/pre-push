#!/usr/bin/env bash
# Blocks a push to a deploy branch (main/develop) when the local CI-mirror
# checks fail, so red code never lands on the branch Render deploys from
# (render.yaml -> autoDeployTrigger: checksPass).
#
# Only deploy branches are gated; feature branches push freely.
# Emergency bypass:  git push --no-verify
#
# Enable once per clone:  git config core.hooksPath .githooks
set -uo pipefail

repo_root="$(git rev-parse --show-toplevel)"
gate_branches_re='^refs/heads/(main|develop)$'

pushing_to_deploy_branch=0
while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip branch deletions (local sha is all zeros).
  case "$local_sha" in *[!0]*) : ;; *) continue ;; esac
  if [[ "$remote_ref" =~ $gate_branches_re ]]; then
    pushing_to_deploy_branch=1
  fi
done

if [ "$pushing_to_deploy_branch" -eq 0 ]; then
  exit 0
fi

# Git exports GIT_DIR/GIT_WORK_TREE/GIT_INDEX_FILE while running hooks. Nested
# git-based tools (notably `flutter`, which shells out to git to detect its own
# SDK version) inherit these and misbehave — flutter reports version
# "0.0.0-unknown" and `flutter pub get` fails. Strip them so sub-tools rediscover
# their own git context from the filesystem.
for _v in $(env | sed -n 's/^\(GIT_[A-Za-z0-9_]*\)=.*/\1/p'); do
  unset "$_v"
done

echo "pre-push: pushing to a deploy branch — running local CI checks (mirrors GitHub CI)."
echo "          bypass in an emergency with: git push --no-verify"

if [ ! -x "$repo_root/scripts/ci-local.sh" ]; then
  echo "pre-push: scripts/ci-local.sh missing or not executable — cannot verify; aborting." >&2
  echo "          run: chmod +x scripts/ci-local.sh   (or push with --no-verify)" >&2
  exit 1
fi

if ! "$repo_root/scripts/ci-local.sh"; then
  echo "pre-push: blocked — fix the failures above, or push with --no-verify to override." >&2
  exit 1
fi

exit 0
